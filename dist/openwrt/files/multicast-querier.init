#!/bin/sh /etc/rc.common

START=99
USE_PROCD=1

PROG=/usr/bin/multicast-querier

start_service() {
    procd_open_instance
    # By default, runs on br-lan. Change this to your target interface.
    procd_set_param command $PROG br-lan
    procd_set_param respawn
    procd_set_param stdout 1
    procd_set_param stderr 1
    procd_close_instance
}
